# Database Configuration
DATABASE_URL=mysql://user:password@localhost:3306/daywise_db

# JWT & Authentication
JWT_SECRET=your_jwt_secret_key_min_32_chars_recommended

# Manus OAuth Configuration
VITE_APP_ID=your_manus_app_id
OAUTH_SERVER_URL=https://oauth.manus.im
VITE_OAUTH_PORTAL_URL=https://app.manus.im
VITE_OAUTH_PROVIDER_HINT=google

# Node Environment
# Use production for Vercel/Docker deployments
NODE_ENV=development

# Server Configuration (Optional)
PORT=3000

# LLM routing and failover
LLM_PROVIDER_PRIMARY=gemini
LLM_PROVIDER_FALLBACK_1=forge
LLM_PROVIDER_FALLBACK_2=none
LLM_MODEL_PRIMARY=gemini-1.5-flash
LLM_MODEL_FALLBACK_1=gpt-4o-mini
LLM_MODEL_FALLBACK_2=
LLM_FAILOVER_TIMEOUT_MS=8000

# Gemini (primary free-tier provider)
GEMINI_API_KEY=your_gemini_api_key

# Optional fallback providers
OPENROUTER_API_KEY=optional_openrouter_api_key
GROQ_API_KEY=optional_groq_api_key

# Forge (OpenAI-compatible fallback)
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=your_forge_api_key

# Optional: Owner OpenID (for admin features)
OWNER_OPEN_ID=optional_admin_user_id
