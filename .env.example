# Database Configuration
DATABASE_URL=mysql://user:password@localhost:3306/daywise_db

# JWT & Authentication
JWT_SECRET=your_jwt_secret_key_min_32_chars_recommended

# Manus OAuth Configuration
VITE_APP_ID=your_manus_app_id
OAUTH_SERVER_URL=https://oauth.manus.im
VITE_OAUTH_PORTAL_URL=https://app.manus.im

# Node Environment
# Use production for Vercel/Docker deployments
NODE_ENV=development

# Server Configuration (Optional)
PORT=3000

# LLM & AI Integration (Forge API - OpenAI Compatible)
# These are used for AI advice generation via the Forge API proxy
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=your_forge_api_key

# Optional: Owner OpenID (for admin features)
OWNER_OPEN_ID=optional_admin_user_id
